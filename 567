def inference_with_openai_api(
    video1,
    video2,
    prompt,
    idx="test.mp4",
    model_id = DASH_MODEL_ID,
    video_type='url'
):
    video1_msg = {"type": "video_url", "video_url": {"url": video1}}
    video2_msg = {"type": "video_url", "video_url": {"url": video2}}
    
    client = OpenAI(
        api_key = "",
        base_url = "http://localhost:8015/v1",
    )    
    messages = [
        {
            "role": "system",
            "content": "You are an expert Video Description Specialist. Your task is to generate highly detailed, professional, and visually evocative captions for video content."
        },
        {
            "role": "user",
            "content": [
                video1_msg,
                video2_msg,
                {"type": "text", "text": prompt},
            ]
        }
    ]
    completion = client.chat.completions.create(
        model = model_id,
        messages = messages,
        max_tokens = 10000,
        extra_body={"mm_processor_kwargs": {"fps": 8, "do_sample_frames": True, "max_pixels": 460800}}
    )
    return idx, completion.choices[0].message.content

def inference_with_openai_api_single(
    video1,
    prompt,
    idx="test.mp4",
    model_id = DASH_MODEL_ID,
    video_type='url'
):
    video1_msg = {"type": "video_url", "video_url": {"url": video1}}
    
    client = OpenAI(
        api_key = "",
        base_url = "http://localhost:8015/v1",
    )    
    messages = [
        {
            "role": "system",
            "content": ""
        },
        {
            "role": "user",
            "content": [
                video1_msg,
                {"type": "text", "text": prompt},
            ]
        }
    ]
    try:
        completion = client.chat.completions.create(
            model = model_id,
            messages = messages,
            max_tokens = 10000,
            extra_body={"mm_processor_kwargs": {"fps": 2, "do_sample_frames": True, "max_pixels": 460800}}
        )
    except Exception as e:
        print(f"{e}")
        return idx, ""

    return idx, completion.choices[0].message.content


import json
import pathos
import os
from tqdm import tqdm
from post_vllm_infer_qwen3 import inference_with_openai_api_single

pool = pathos.multiprocessing.ProcessPool(nodes=16)

datasets = [
    '/data/hwx1479485/HOI/videos_HOI_subset',
    '/data/hwx1479485/videos/20260114_human_action',
    '/data/hwx1479485/videos/20260126_2.6.1.seedance.1.tarsier2',
    '/data/hwx1479485/videos/DREAM-1K_videos',
]

INFER_PROMPT = "Describe this video in detail."

base_dir = "captions"

for dataset in datasets:
    print(f"processing: {dataset}")
    dataset_name = dataset.split("/")[-1]
    os.makedirs(f"{base_dir}/{dataset_name}", exist_ok=True)
    old_videos = []
    prompts = []
    ids = []
    for video_name in os.listdir(dataset):
        if os.path.exists(f"{base_dir}/{dataset_name}/{video_name}.txt"):
            continue
        old_videos.append("file://" + (os.path.join(dataset, video_name)))
        prompts.append(INFER_PROMPT)
        ids.append(video_name)

    results = pool.imap(inference_with_openai_api_single, old_videos, prompts, ids)
    pbar = tqdm(total=len(prompts))
    for video, res in results:
        with open(f"{base_dir}/{dataset_name}/{video}.txt", "w") as f:
            f.write(res)
        pbar.update(1)
