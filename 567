def parse_evaluation_response(response_text: str) -> Optional[Dict[str, str]]:
    """
    解析LLM返回的JSON评估结果
    
    Args:
        response_text: LLM返回的文本（应该是JSON格式）
        
    Returns:
        字典，键为维度名称，值为Y/N/F，解析失败返回None
    """
    if not response_text:
        return None
    
    required_dims = ["Subject", "Attributes", "Action", "Environment", "Camera_Tech", "Surroundings", "Summary"]
    
    # 方法1: 尝试直接解析JSON
    try:
        # 提取JSON部分（可能被其他文本包围）
        json_match = re.search(r'\{[^{}]*\}', response_text)
        if json_match:
            json_str = json_match.group()
            result = json.loads(json_str)
            # 验证并规范化
            normalized = {}
            for dim in required_dims:
                if dim in result:
                    val = str(result[dim]).upper().strip()
                    # 必须是单个字符 Y/N/F，拒绝 "Y/N/F" 这种占位符
                    if val in ["Y", "N", "F"]:
                        normalized[dim] = val
                    # 如果不是单字符，不添加到结果中
            if len(normalized) == 7:
                return normalized
    except:
        pass
    
    # 方法2: 正则提取 "Key": "Y/N/F"
    result = {}
    for dim in required_dims:
        # 匹配 "Subject": "Y" 或 "Subject":"Y" 或 Subject: Y
        pattern = rf'["\']?{dim}["\']?\s*:\s*["\']?([YNFynf])["\']?'
        match = re.search(pattern, response_text, re.IGNORECASE)
        if match:
            result[dim] = match.group(1).upper()
    
    if len(result) == 7:
        return result
    
    # 方法3: 从文本中按顺序提取Y/N/F
    all_scores = re.findall(r'\b([YNF])\b', response_text, re.IGNORECASE)
    all_scores = [s.upper() for s in all_scores]
    if len(all_scores) >= 7:
        result = {required_dims[i]: all_scores[i] for i in range(7)}
        return result
    
    return None

def calculate_accuracy(scores: Dict[str, str]) -> float:
    """
    计算准确率：Accuracy = Y / (Y + N + F)
    
    Args:
        scores: 包含各维度Y/N/F评分的字典
        
    Returns:
        准确率（0-1之间的浮点数）
    """
    y_count = sum(1 for score in scores.values() if score == "Y")
    total = len(scores)
    
    if total == 0:
        return 0.0
    
    return y_count / total

def evaluate_video(video_id: str, gt_data: Dict, pred_text: str) -> Dict:
    """
    评估单个视频
    
    Args:
        video_id: 视频ID
        gt_data: GT数据
        pred_text: 预测文本
        
    Returns:
        评估结果字典
    """
    # 构建prompt
    prompt = build_evaluation_prompt(video_id, gt_data, pred_text)
    
    # 调用API
    response = call_openai_api(prompt)
    
    if not response:
        return {
            "video_id": video_id,
            "status": "error",
            "error": "API调用失败",
            "scores": None,
            "accuracy": None
        }
    
    # 解析结果
    scores = parse_evaluation_response(response)
    
    if not scores:
        return {
            "video_id": video_id,
            "status": "error",
            "error": "解析评估结果失败",
            "raw_response": response[:500],  # 保留前500字符用于调试
            "scores": None,
            "accuracy": None
        }
    
    # 计算准确率
    accuracy = calculate_accuracy(scores)
    
    return {
        "video_id": video_id,
        "status": "success",
        "scores": scores,
        "accuracy": accuracy,
        "raw_response": response  # 保留原始响应用于调试
    }

def main():
    """主函数"""
    print("开始加载数据...")
    
    # 加载GT数据
    with open(GT_FILE, 'r', encoding='utf-8') as f:
        gt_data = json.load(f)
    
    # 加载预测数据
    with open(PRED_FILE, 'r', encoding='utf-8') as f:
        pred_data = json.load(f)
    
    print(f"GT数据包含 {len(gt_data)} 个视频")
    print(f"预测数据包含 {len(pred_data)} 个视频")
    
    # 获取共同的视频ID
    common_video_ids = set(gt_data.keys()) & set(pred_data.keys())
    print(f"共同视频数量: {len(common_video_ids)}")
    
    if len(common_video_ids) == 0:
        print("错误：没有找到共同的视频ID！")
        return
    
    # 评估所有视频（使用多线程）
    results = []
    total = len(common_video_ids)
    video_ids_list = sorted(common_video_ids)
    
    def evaluate_single_video(video_id: str, idx: int) -> Dict:
        """评估单个视频的包装函数，用于多线程"""
        result = evaluate_video(
            video_id,
            gt_data[video_id],
            pred_data[video_id]
        )
        
        # 添加GT和Pred信息到结果中
        result["gt"] = gt_data[video_id]
        result["pred"] = pred_data[video_id]
        
        # 线程安全的打印
        with print_lock:
            if result["status"] == "success":
                print(f"[{idx}/{total}] {video_id}: 准确率={result['accuracy']:.4f}, 评分={result['scores']}")
            else:
                print(f"[{idx}/{total}] {video_id}: 错误 - {result.get('error', 'Unknown error')}")
        
        return result
    
    print(f"\n开始多线程评估（{MAX_WORKERS}个线程）...")
    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
        # 提交所有任务
        future_to_video = {
            executor.submit(evaluate_single_video, video_id, idx): video_id 
            for idx, video_id in enumerate(video_ids_list, 1)
        }
        
        # 收集结果（按完成顺序）
        for future in as_completed(future_to_video):
            try:
                result = future.result()
                results.append(result)
            except Exception as e:
                video_id = future_to_video[future]
                with print_lock:
                    print(f"视频 {video_id} 评估时发生异常: {e}")
                results.append({
                    "video_id": video_id,
                    "status": "error",
                    "error": f"评估异常: {str(e)}",
                    "scores": None,
                    "accuracy": None,
                    "gt": gt_data.get(video_id, {}),
                    "pred": pred_data.get(video_id, "")
                })
    
    # 按video_id排序结果，保持一致性
    results.sort(key=lambda x: x["video_id"])
    
    # 计算统计信息
    successful_results = [r for r in results if r["status"] == "success"]
    failed_results = [r for r in results if r["status"] == "error"]
    
    print(f"\n=== 评估完成 ===")
    print(f"成功: {len(successful_results)}")
    print(f"失败: {len(failed_results)}")
    
    # 计算平均准确率
    avg_accuracy = None
    overall_avg_y_rate = None
    if successful_results:
        avg_accuracy = sum(r["accuracy"] for r in successful_results) / len(successful_results)
        print(f"平均准确率: {avg_accuracy:.4f}")
        
        # 计算各维度的Y/N/F统计（7个维度）
        dimension_stats = {
            "Subject": {"Y": 0, "N": 0, "F": 0},
            "Attributes": {"Y": 0, "N": 0, "F": 0},
            "Action": {"Y": 0, "N": 0, "F": 0},
            "Environment": {"Y": 0, "N": 0, "F": 0},
            "Camera_Tech": {"Y": 0, "N": 0, "F": 0},
            "Surroundings": {"Y": 0, "N": 0, "F": 0},
            "Summary": {"Y": 0, "N": 0, "F": 0},
        }
        
        for result in successful_results:
            for dim, score in result["scores"].items():
                if dim in dimension_stats and score in dimension_stats[dim]:
                    dimension_stats[dim][score] += 1
        
        print("\n=== 各维度统计 ===")
        dimension_y_rates = {}
        for dim, stats in dimension_stats.items():
            total_dim = sum(stats.values())
            y_rate = stats["Y"] / total_dim if total_dim > 0 else 0
            dimension_y_rates[dim] = y_rate
            print(f"{dim}: Y={stats['Y']} N={stats['N']} F={stats['F']} (Y率: {y_rate:.4f})")
        
        # 计算总体平均Y率
        if dimension_y_rates:
            overall_avg_y_rate = sum(dimension_y_rates.values()) / len(dimension_y_rates)
            print(f"\n=== 总体平均Y率 ===")
            print(f"所有维度平均Y率: {overall_avg_y_rate:.4f}")
    
    # 保存结果
    output = {
        "summary": {
            "total_videos": total,
            "successful": len(successful_results),
            "failed": len(failed_results),
            "average_accuracy": avg_accuracy,
            "overall_avg_y_rate": overall_avg_y_rate,
            "dimension_rates": dimension_y_rates,
        },
        "results": results
    }
    
    with open(OUTPUT_FILE, 'w', encoding='utf-8') as f:
        json.dump(output, f, ensure_ascii=False, indent=2)
    
    print(f"\n结果已保存到: {OUTPUT_FILE}")

if __name__ == "__main__":
    main()

