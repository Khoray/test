def call_openai_api(prompt_text: str, max_retries: int = 3) -> Optional[str]:
    """
    调用OpenAI API获取评估结果
    
    Args:
        prompt_text: 评估prompt
        max_retries: 最大重试次数
        
    Returns:
        模型返回的文本，失败返回None
    """
    client = OpenAI(
        api_key=OPENAI_API_KEY,
        base_url=OPENAI_BASE_URL
    )
    
    for attempt in range(max_retries):
        try:
            response = client.chat.completions.create(
                model=OPENAI_MODEL,
                messages=[
                    {"role": "user", "content": prompt_text}
                ],
                max_tokens=1024,  # 7个维度需要足够token
                temperature=0,
                timeout=60
            )
            
            # 提取返回的文本
            if response.choices and len(response.choices) > 0:
                text_value = response.choices[0].message.content
                if text_value:
                    return text_value.strip()
                
        except Exception as e:
            with print_lock:
                print(f"API调用失败 (尝试 {attempt + 1}/{max_retries}): {e}")
            if attempt < max_retries - 1:
                time.sleep(2)  # 等待后重试
    
    return None

def build_evaluation_prompt(video_id: str, gt_data: Dict, pred_text: str) -> str:
